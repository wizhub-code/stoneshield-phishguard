# Stoneshield PhishGuard — Environment Configuration
# Copy this to .env and fill in your values

# App
APP_NAME=Stoneshield PhishGuard
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Security — CHANGE THESE IN PRODUCTION
SECRET_KEY=supersecretkey-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./stoneshield.db

# CORS — add your frontend domain in production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:8000"]
